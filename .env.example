# Frontend Environment Variables (Vite)
# Copy this file to .env.local for local development

# Chat API URL — points to your Cloudflare Worker
# Local dev: http://localhost:8787/api/chat (default if not set)
# Production: https://mhaseeb-chat.<your-subdomain>.workers.dev/api/chat
VITE_CHAT_API_URL=http://localhost:8787/api/chat
